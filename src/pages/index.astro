---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section
      id="hero"
      class:list={[
        "pt-8 pb-8",
        "border-b border-border",
        "rounded-xl",
        "bg-gradient-to-br from-accent/8 via-background to-[color:var(--accent-2)]/8",
        "[animation:fade-up_0.5s_ease_both]",
      ]}
    >
      <span class="mb-3 inline-block rounded-full border border-accent/30 bg-accent/10 px-3 py-1 text-sm font-medium text-accent">
        // Tobias Geistert
      </span>

      <div class="flex items-end gap-0">
        <h1 class="my-2 text-4xl font-bold sm:my-4 sm:text-5xl">
          Hey, schön dass du hier bist!
        </h1>
        <span
          class="mb-2 ml-1 inline-block h-8 w-0.5 translate-y-0 bg-accent sm:mb-4 sm:h-10"
          style="animation: blink-cursor 1s step-end infinite;"
          aria-hidden="true"
        ></span>
      </div>

      <div class="mb-1 h-0.5 w-16 rounded-full bg-gradient-to-r from-accent to-[color:var(--accent-2)]"></div>

      <p class="mt-4">
        Ich bin Tobias und das hier ist mein kleines Stück Internet. Ich bastle gerne an Projekten herum und denke laut nach. Auf diesem Blog halte ich fest, was mich beschäftigt — ob Technik-Notizen, Linux-Tipps oder einfach persönliche Gedanken. Kein Perfektionismus, nur echte Einblicke.
      </p>

      <div class="mt-4 flex flex-wrap items-center gap-3">
        {
          SOCIALS.length > 0 && <Socials />
        }
        <a
          target="_blank"
          href="/rss.xml"
          class="inline-flex items-center gap-1.5 rounded-full border border-border px-3 py-1 text-sm hover:border-accent hover:text-accent transition-colors"
          aria-label="RSS Feed"
          title="RSS Feed"
        >
          <IconRss width={14} height={14} class="stroke-current" />
          RSS
        </a>
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Recent Posts</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
